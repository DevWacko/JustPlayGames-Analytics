# ─── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_server_id_here
DISCORD_CHANNEL_ID=channel_id_to_post_sales_in

# ─── Roblox ────────────────────────────────────────────────
# Your .ROBLOSECURITY cookie value (from browser devtools)
# Must be from an account with Group Revenue access (owner/treasurer)
ROBLOX_COOKIE=your_roblosecurity_cookie_here
ROBLOX_GROUP_ID=your_group_id_here
